# Copiar a .env en local. En Vercel: Settings → Environment Variables (Production + Preview).
# Tras cambiar variables REACT_APP_*, hace falta REDEPLOY (se inyectan en build).

REACT_APP_SUPABASE_URL=https://TU_REF.supabase.co
REACT_APP_SUPABASE_ANON_KEY=tu_anon_key

# UUID del organizador para ranking público /ranking y /ranking/como-funciona (sin ?org=)
REACT_APP_RIVIERA_PUBLIC_ORGANIZADOR_ID=

# No uses la service role en REACT_APP_*: el bundle del navegador la expone.
# Operaciones que requieran service role → Edge Functions o backend, nunca en CRA.
#
# Edge Functions (supabase secrets set) — ver supabase/functions/procesar-notificaciones-evento/README.md
# NOTIFICACIONES_WEBHOOK_SECRET=secreto-largo-aleatorio  (header x-notificaciones-secret en el webhook)
