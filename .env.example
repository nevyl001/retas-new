# Supabase
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# URL pública de la app (auth redirects, enlaces compartidos)
REACT_APP_PUBLIC_URL=https://appriviera.rivieraopen.com

# Sitio web oficial (ranking global y perfiles de jugador)
REACT_APP_RIVIERA_OFFICIAL_URL=https://www.rivieraopen.com

# Supabase Edge Functions secrets (supabase secrets set)
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=Riviera Open <noreply@appriviera.rivieraopen.com>
# APP_PUBLIC_URL=https://appriviera.rivieraopen.com
# Si RESEND_FROM usa @rivieraopen.com sin appriviera, se fuerza noreply@appriviera.rivieraopen.com
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
