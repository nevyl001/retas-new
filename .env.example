# Supabase
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# URL pública de la app (auth redirects, enlaces compartidos)
REACT_APP_PUBLIC_URL=https://appriviera.rivieraopen.com

# Sitio web oficial (ranking global y perfiles de jugador)
REACT_APP_RIVIERA_OFFICIAL_URL=https://www.rivieraopen.com

# PEDS v1 — shell estructural de vistas públicas (Sprint 2+).
# ON por defecto en build. Para rollback temporal: REACT_APP_PUB_DS_V2=false

# Supabase Edge Functions secrets (supabase secrets set) — NUNCA en REACT_APP_*
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=Riviera Open <noreply@appriviera.rivieraopen.com>
# APP_PUBLIC_URL=https://appriviera.rivieraopen.com
# Si RESEND_FROM usa @rivieraopen.com sin appriviera, se fuerza noreply@appriviera.rivieraopen.com
# NOTIFICACIONES_WEBHOOK_SECRET=genera-un-secreto-largo-aleatorio
#   → procesar-notificaciones-evento: header HTTP x-notificaciones-secret con el mismo valor.
#   Ver supabase/functions/procesar-notificaciones-evento/README.md

# Archivado de retas (rivieraopen.com) — SOLO Edge Function reta-archive-proxy
# NO usar REACT_APP_ (el secreto no debe ir al bundle del navegador).
# Configurar en Supabase: Dashboard → Edge Functions → Secrets, o:
#   supabase secrets set RIVIERAOPEN_API_BASE=https://rivieraopen.com RETA_ARCHIVE_SECRET=<mismo que rivieraopen.com>
# Para functions serve local: añade las mismas claves a .env.local (no se commitean).
# RIVIERAOPEN_API_BASE=https://rivieraopen.com
# RETA_ARCHIVE_SECRET=
