{
  "name": "riviera-app",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "@tabler/icons-webfont": "^3.34.0",
    "@types/node": "^16.18.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "typescript": "^4.9.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "react-scripts test --watchAll=false --passWithNoTests",
    "test:player-identity": "react-scripts test --watchAll=false --testPathPattern=playerIdentityService.test.ts",
    "test:public-player-profile": "react-scripts test --watchAll=false --testPathPattern=publicPlayerProfile.test.ts",
    "test:career-pipeline": "react-scripts test --watchAll=false --testPathPattern=careerEventPipeline.e2e.test.ts",
    "test:player-points": "react-scripts test --watchAll=false --testPathPattern=playerPointsBreakdown.test.ts",
    "test:career-integrity": "react-scripts test --watchAll=false --testPathPattern=orphanCareerProfileIntegrity.test.ts",
    "audit:career-integrity": "node scripts/audit-career-integrity.mjs",
    "audit:ranking-points-daniel": "node scripts/audit-ranking-points-daniel.mjs",
    "audit:event-parent-integrity": "node scripts/audit-event-parent-integrity.mjs",
    "audit:public-event-hydration": "node scripts/audit-public-event-player-hydration.mjs",
    "diagnose:career-host": "node scripts/diagnose-career-event-host-organizer.mjs",
    "verify:career-integrity": "npm run test:career-pipeline && npm run test:player-points && npm run test:career-integrity && npm run test:career-integrity-strict && npm run audit:career-integrity -- --offline && npm run verify:public-player",
    "test:career-integrity-strict": "react-scripts test --watchAll=false --testPathPattern=careerIntegrity.strict.test.ts",
    "e2e:public-player-profile": "node scripts/validate-career-totals-ui.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "verify:public-player": "npm run typecheck && CI=true npm test && npm run test:player-identity && npm run test:public-player-profile && npm run build",
    "eject": "react-scripts eject",
    "update-icons": "node scripts/update-icons.js",
    "email-hero-assets": "node scripts/generate-email-hero-assets.mjs",
    "gen:types": "supabase gen types typescript --project-id giswxhmgjepoobdoljb --schema public > src/lib/database.types.ts"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "sharp": "^0.34.5",
    "supabase": "^2.102.0"
  }
}
